{
  "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/.codex",
      "!**/drizzle/migration",
      "!**/*.css",
      "!src/tests/fixtures/data",
      "!src/tests/overview/fixtures/data",
      "!apps/data-pipeline/tests/fixtures"
    ],
    "maxSize": 4000000
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "formatWithErrors": true,
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "asNeeded"
    }
  },
  "html": {
    "formatter": {
      "enabled": true
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "domains": {
      "next": "all",
      "react": "all"
    },
    "rules": {
      "style": {
        "useComponentExportOnlyModules": "off",
        "noUnusedTemplateLiteral": "off",
        "useImportType": "warn",
        "useLiteralEnumMembers": "error",
        "useNodejsImportProtocol": "error",
        "useAsConstAssertion": "error",
        "useEnumInitializers": "error",
        "useSelfClosingElements": "error",
        "useConst": "error",
        "useSingleVarDeclarator": "error",
        "useNumberNamespace": "error",
        "noInferrableTypes": "error",
        "useExponentiationOperator": "error",
        "useTemplate": "error",
        "noParameterAssign": {
          "level": "error",
          "options": {}
        },
        "noNonNullAssertion": "error",
        "useDefaultParameterLast": "error",
        "useExportType": "error",
        "noUselessElse": "error",
        "useShorthandFunctionType": "error",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "process": "Use '@/env/(client|server)' instead",
              "next/router": "Use 'next/navigation' instead",
              "@/components/originui/dialog": "If no good reason, use '@/components/ui/dialog' instead",
              "@/components/originui/button": "If no good reason, use '@/components/ui/button' instead",
              "@/components/originui/badge": "If no good reason, use '@/components/ui/badge' instead",
              "@/components/originui/popover": "If no good reason, use '@/components/ui/popover' instead"
            }
          }
        }
      },
      "a11y": {
        "useAriaPropsForRole": "off",
        "useFocusableInteractive": "off",
        "useSemanticElements": "off",
        "noRedundantRoles": "off",
        "noSvgWithoutTitle": "off",
        "useKeyWithClickEvents": "off",
        "noLabelWithoutControl": "off",
        "noAutofocus": "off"
      },
      "correctness": {
        "useParseIntRadix": "off",
        "useUniqueElementIds": "off",
        "noNestedComponentDefinitions": "off",
        "useExhaustiveDependencies": "off",
        "noChildrenProp": "off",
        "noUnusedImports": {
          "level": "warn",
          "fix": "safe"
        },
        "noUnusedFunctionParameters": "off",
        "noUnusedVariables": "off"
      },
      "nursery": {
        "useSortedClasses": {
          "level": "error",
          "fix": "safe",
          "options": {
            "functions": ["clsx", "cva", "tw", "cn"]
          }
        }
      },
      "complexity": {
        "noForEach": "off",
        "noBannedTypes": "off",
        "noUselessFragments": {
          "fix": "safe",
          "level": "warn"
        }
      },
      "suspicious": {
        "noArrayIndexKey": "off",
        "noDocumentCookie": "off",
        "noExplicitAny": "error",
        "noReactForwardRef": "off"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      },
      "performance": {
        "noAccumulatingSpread": "off",
        "noImgElement": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/lib/papierkram-typescript-sdk/**", "src/lib/posthog-typescript-sdk/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off",
            "noThenProperty": "off",
            "noPrototypeBuiltins": "off",
            "useIterableCallbackReturn": "off"
          }
        }
      }
    }
  ]
}
