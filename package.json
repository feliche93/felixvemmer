{
  "name": "next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "next:dev": "next dev",
    "next:build": "next build",
    "next:start": "next start",
    "content-collections:watch": "content-collections watch",
    "content-collections:build": "content-collections build",
    "dev": "./scripts/with-infisical.sh bun run --parallel content-collections:watch next:dev",
    "build": "./scripts/with-infisical.sh sh -c 'bun run content-collections:build && bun run next:build'",
    "start": "./scripts/with-infisical.sh bun run next:start",
    "lint": "biome check src drizzle scripts content-collections.ts && prettier . --check",
    "lint:fix": "biome check src drizzle scripts content-collections.ts --write && prettier . --write --list-different",
    "format": "biome format . --write",
    "eslint": "bun run --parallel eslint:src eslint:drizzle eslint:content eslint:scripts",
    "eslint:src": "NODE_OPTIONS=\"--max-old-space-size=8192\" bunx --bun eslint src --no-error-on-unmatched-pattern",
    "eslint:drizzle": "NODE_OPTIONS=\"--max-old-space-size=8192\" bunx --bun eslint drizzle --no-error-on-unmatched-pattern",
    "eslint:content": "NODE_OPTIONS=\"--max-old-space-size=8192\" bunx --bun eslint content-collections.ts --no-error-on-unmatched-pattern",
    "eslint:scripts": "NODE_OPTIONS=\"--max-old-space-size=8192\" bunx --bun eslint scripts --no-error-on-unmatched-pattern",
    "typecheck": "NODE_OPTIONS=\"--max-old-space-size=8192\" bunx --bun tsc --pretty --noEmit",
    "checks": "bun run typecheck && bun run lint:fix && bun run eslint",
    "generate": "./scripts/with-infisical.sh drizzle-kit generate --config=drizzle.config.ts",
    "auth-schema:generate": "./scripts/with-infisical.sh bunx --bun -y @better-auth/cli generate -y --config src/lib/auth/index.ts --output ./drizzle/schema/auth/schema.ts && biome check ./drizzle/schema/auth/** --write",
    "generate-custom": "./scripts/with-infisical.sh drizzle-kit generate --custom --config=drizzle.config.ts",
    "migrate": "./scripts/with-infisical.sh drizzle-kit migrate --config=drizzle.config.ts",
    "studio": "./scripts/with-infisical.sh drizzle-kit studio --config=drizzle.config.ts",
    "update-pg": "./scripts/with-infisical.sh drizzle-kit up:pg --config=drizzle.config.ts",
    "check": "./scripts/with-infisical.sh drizzle-kit check:pg --config=drizzle.config.ts",
    "drop": "./scripts/with-infisical.sh drizzle-kit drop --config=drizzle.config.ts",
    "generate-content": "bun run content-collections:build",
    "generate-posthog-sdk": "bun run openapi-typescript-codegen --input ./openapi-specs/posthog.yaml --output ./src/lib/posthog-typescript-sdk --name client --useOptions --client fetch --useUnionTypes",
    "generate-papierkram-sdk": "bun run openapi-typescript-codegen --input https://felixvemmer.papierkram.de/api/v1/api-docs/api/v1/swagger.json --output ./src/lib/papierkram-typescript-sdk --name client --useOptions --client fetch --useUnionTypes",
    "migrate-clerk-users": "./scripts/with-infisical.sh bun run scripts/migrate-clerk-users-to-better-auth.ts",
    "clean": "rm -rf bun.lock pnpm-lock.yaml node_modules .next",
    "env:ports": "bun --bun ./scripts/setup-env.ts ports",
    "setup-env": "bun run env:ports",
    "dev:session:start": "bun --bun ./scripts/dev-tmux.ts start",
    "dev:session:logs": "bun --bun ./scripts/dev-tmux.ts logs",
    "dev:session:logs-live": "bun --bun ./scripts/dev-tmux.ts logs-live",
    "dev:session:stop": "bun --bun ./scripts/dev-tmux.ts stop",
    "dev:session:stop-all": "bun --bun ./scripts/dev-tmux.ts stop-all",
    "dev:session:attach": "bun --bun ./scripts/dev-tmux.ts attach",
    "dev:session:list": "bun --bun ./scripts/dev-tmux.ts list",
    "dev:open:next": "bun --bun ./scripts/open-local-dev-link.ts next",
    "dev:open:drizzle": "bun --bun ./scripts/open-local-dev-link.ts drizzle_studio",
    "postinstall": "biome check package.json --write > /dev/null 2>&1 && next telemetry disable > /dev/null 2>&1"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.5.0",
    "@calcom/embed-react": "^1.5.2",
    "@content-collections/mdx": "^0.2.0",
    "@content-collections/next": "^0.2.4",
    "@fumadocs/content-collections": "^1.1.8",
    "@headlessui/tailwindcss": "^0.2.2",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@instructor-ai/instructor": "^1.7.0",
    "@lemonsqueezy/lemonsqueezy.js": "^4.0.0",
    "@neondatabase/serverless": "^0.10.4",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tailwindcss/postcss": "^4.2.1",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/table-core": "^8.21.3",
    "@tremor/react": "^3.18.7",
    "@types/react": "19.0.8",
    "@types/react-dom": "19.0.3",
    "better-auth": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cookie-cutter": "^0.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.4.2",
    "fumadocs-core": "^15.0.6",
    "fumadocs-ui": "^14.7.0",
    "input-otp": "^1.4.2",
    "jotai": "^2.18.0",
    "lucide-react": "^0.575.0",
    "nanoid": "^5.1.6",
    "next": "^16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.8",
    "openai": "^4.83.0",
    "posthog-js": "^1.356.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-lite-youtube-embed": "^3.5.1",
    "react-tweet": "^3.3.0",
    "react-wrap-balancer": "^1.1.1",
    "resend": "^6.9.3",
    "rss": "^1.2.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.20",
    "@biomejs/biome": "2.4.4",
    "@content-collections/cli": "^0.1.9",
    "@content-collections/core": "^0.14.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/dinero.js": "^1.9.4",
    "@types/rss": "^0.0.32",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.2",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-sort-exports": "^0.9.1",
    "nano-staged": "^0.9.0",
    "openapi-typescript-codegen": "^0.29.0",
    "postcss": "^8.5.2",
    "prettier": "^3.8.1",
    "schema-dts": "^1.1.5",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.19.2",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "bun@1.3.10",
  "nano-staged": {
    "*.{js,ts,cjs,mjs,jsx,tsx,json,jsonc,html}": [
      "biome check --staged --write --no-errors-on-unmatched"
    ],
    "*.{md,mdx,yml,yaml,sass,scss,css}": [
      "prettier --write"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "bunx --bun nano-staged"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@swc/core",
    "@tailwindcss/oxide",
    "esbuild",
    "sharp",
    "simple-git-hooks"
  ]
}
